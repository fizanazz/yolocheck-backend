# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=YOLOCheck
APP_VERSION=1.0.0
DEBUG=False

# FIX 8: ALLOWED_ORIGINS must include your frontend dev server port.
# Vite runs on 5173 by default. Add any other origin you deploy to.
# Keep as comma-separated — the config validator handles parsing.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=scan-images

# ── Google Gemini ──────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ── YOLO ───────────────────────────────────────────────────────────────────────
# Path to your trained YOLOv11 weights file.
# Copy your best.pt here: ml/best.pt
MODEL_PATH=ml/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
